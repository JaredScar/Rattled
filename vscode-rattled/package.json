{
  "name": "rattled",
  "displayName": "Rattled Language",
  "description": "Syntax highlighting for the Rattled (.ry) programming language",
  "version": "0.1.0",
  "publisher": "rattled",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rattled-lang/rattled"
  },
  "contributes": {
    "languages": [
      {
        "id": "rattled",
        "aliases": ["Rattled", "ry"],
        "extensions": [".ry"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rattled",
        "scopeName": "source.rattled",
        "path": "./syntaxes/rattled.tmLanguage.json"
      }
    ]
  }
}
